# =============================================================================
# ENG Quest / A-KEN Quest — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Files that reference these variables:
#   backend/server.js            — Node.js backend proxy
#   backend/docker-compose.yml   — Docker deployment
#   android/app/build.gradle.kts — Android release signing
#   lib/core/config/app_config.dart      — Flutter app (direct constant, not env)
#   lib/core/billing/billing_config.dart — RevenueCat (direct constant, not env)
#   lib/core/firebase/firebase_options.dart — Firebase (direct constant, not env)
#
# NOTE: Flutter Dart constants in lib/ are not read from env at runtime.
# They must be replaced manually in source or via build-time substitution.
# =============================================================================


# =============================================================================
# Firebase
# =============================================================================
# Firebase project ID — used by backend (firebase-admin) to verify auth tokens.
# Find at: Firebase Console > Project Settings > General > Project ID
FIREBASE_PROJECT_ID=engquest-mvp

# Path to Firebase Admin SDK service account JSON key (backend / Docker only).
# Generate at: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Mount as a volume; never bake into Docker image.
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-service-account.json

# -- Flutter Firebase credentials (set in lib/core/firebase/firebase_options.dart) --
# These are NOT read from env at runtime; update the Dart source directly.
#
# Web API key — Firebase Console > Project Settings > Your apps > Web app > apiKey
FIREBASE_WEB_API_KEY=REPLACE_WITH_WEB_API_KEY
#
# Web App ID — Firebase Console > Project Settings > Your apps > Web app > appId
FIREBASE_WEB_APP_ID=REPLACE_WITH_WEB_APP_ID
#
# Android API key
FIREBASE_ANDROID_API_KEY=REPLACE_WITH_ANDROID_API_KEY
#
# Android App ID
FIREBASE_ANDROID_APP_ID=REPLACE_WITH_ANDROID_APP_ID
#
# iOS API key
FIREBASE_IOS_API_KEY=REPLACE_WITH_IOS_API_KEY
#
# iOS App ID
FIREBASE_IOS_APP_ID=REPLACE_WITH_IOS_APP_ID
#
# Sender ID (shared across platforms) — Firebase Console > Project Settings > Cloud Messaging
FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID


# =============================================================================
# Anthropic / Claude API
# =============================================================================
# Secret Anthropic API key — used by the backend proxy to call Claude on behalf of users.
# The key is kept server-side so it is never exposed to Flutter clients.
# Get at: https://console.anthropic.com/settings/api-keys
CLAUDE_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# -- Flutter direct constant (lib/core/config/app_config.dart) --
# kClaudeApiKey in Dart is set to 'REPLACE_WITH_KEY' which triggers offline mode.
# In production the Flutter app calls the backend proxy (/claude/messages) instead
# of hitting the Anthropic API directly, so this constant can remain as-is.


# =============================================================================
# Stripe
# =============================================================================
# Stripe secret key — server-side only. NEVER expose to clients.
# Live key: sk_live_... | Test key: sk_test_...
# Get at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# Stripe webhook signing secret — used to verify webhook payloads from Stripe.
# Get at: https://dashboard.stripe.com/webhooks > select endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET

# Stripe Price ID for the A-KEN Quest monthly subscription (¥999/month).
# Get at: https://dashboard.stripe.com/products > create product > copy price ID
STRIPE_PRICE_ID=price_aken_monthly_999


# =============================================================================
# RevenueCat (Flutter in-app billing — iOS / Android / Web)
# =============================================================================
# NOTE: RevenueCat API keys are set as Dart constants in
#       lib/core/billing/billing_config.dart, not read from env at runtime.
#       Listed here for documentation / secret management purposes.
#
# iOS "public app-specific" key — RevenueCat dashboard > Apps > iOS > API key
REVENUECAT_API_KEY_IOS=rc_placeholder_aken_ios
#
# Android "public app-specific" key — RevenueCat dashboard > Apps > Android > API key
REVENUECAT_API_KEY_ANDROID=rc_placeholder_aken_android
#
# Web Billing API key — RevenueCat dashboard > Apps > Web > API key
REVENUECAT_API_KEY_WEB=rc_placeholder_aken_web


# =============================================================================
# Backend Server
# =============================================================================
# TCP port the Node.js backend listens on (default: 3001).
PORT=3001

# Runtime environment. Use 'development' locally (relaxes HTTPS + CORS checks).
# Set to 'production' on VPS.
NODE_ENV=production

# Comma-separated list of allowed CORS origins (production).
# In development mode all localhost origins are allowed automatically.
ALLOWED_ORIGINS=https://akenquest.jp,https://www.akenquest.jp,https://api.akenquest.jp


# =============================================================================
# Android Release Signing
# =============================================================================
# Referenced in android/app/build.gradle.kts signingConfigs { release { ... } }
# Required only for release builds. Falls back to debug signing if STORE_FILE is absent.
#
# Path to the .jks keystore file (relative to android/app/ or absolute).
STORE_FILE=keystore/release.jks
#
# Keystore password (set when creating the keystore with keytool).
STORE_PASSWORD=REPLACE_WITH_KEYSTORE_PASSWORD
#
# Key alias within the keystore (default: "akenquest").
KEY_ALIAS=akenquest
#
# Key password for the alias (often the same as STORE_PASSWORD).
KEY_PASSWORD=REPLACE_WITH_KEY_PASSWORD
